<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="4dp"
    android:layout_marginVertical="6dp"
    app:cardCornerRadius="10dp"
    app:cardElevation="3dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp">

        <ImageView
            android:id="@+id/imgItemFoto"
            android:layout_width="75dp"
            android:layout_height="75dp"
            android:background="#E0E0E0"
            android:scaleType="centerCrop"
            android:layout_marginRight="12dp"
            android:src="@android:drawable/ic_menu_gallery" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:id="@+id/txtItemEmail"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="email@barista.com"
                android:textStyle="bold"
                android:textColor="#2C3E50"
                android:textSize="15sp"
                android:layout_marginBottom="2dp"/>

            <TextView
                android:id="@+id/txtItemWaktu"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Waktu: 2026-06-12 08:00:00"
                android:textColor="#7F8C8D"
                android:textSize="13sp"
                android:layout_marginBottom="2dp"/>

            <TextView
                android:id="@+id/txtItemLokasi"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Lokasi: Mendeteksi Alamat..."
                android:textColor="#34495E"
                android:textSize="12sp"
                android:maxLines="2"
                android:ellipsize="end"/>
        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>