<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="3dp"
    app:cardBackgroundColor="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="14dp">

        <!-- Row 1: Nama + Tipe badge -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="6dp">

            <TextView
                android:id="@+id/tvNamaPengajuan"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Nama Barista"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#2C3E50" />

            <TextView
                android:id="@+id/tvTipePengajuan"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Pengambilan"
                android:textSize="10sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:paddingHorizontal="10dp"
                android:paddingVertical="3dp" />
        </LinearLayout>

        <!-- Row 2: Tanggal + Nominal -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="4dp">

            <TextView
                android:id="@+id/tvTanggalPengajuan"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="2026-06-16"
                android:textSize="12sp"
                android:textColor="#7F8C8D" />

            <TextView
                android:id="@+id/tvNominalPengajuan"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Rp 50.000"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="#1B5E3B" />
        </LinearLayout>

        <!-- Row 3: Status badge (for non-menunggu) -->
        <TextView
            android:id="@+id/tvStatusPengajuan"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Menunggu"
            android:textSize="10sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:paddingHorizontal="10dp"
            android:paddingVertical="3dp"
            android:layout_marginBottom="8dp"
            android:visibility="gone" />

        <!-- Row 4: Action Buttons -->
        <LinearLayout
            android:id="@+id/layoutAksi"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="end">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnTolak"
                android:layout_width="wrap_content"
                android:layout_height="34dp"
                android:text="Tolak"
                android:textSize="11sp"
                android:textColor="#FFFFFF"
                android:backgroundTint="#E53935"
                app:cornerRadius="6dp"
                android:minWidth="0dp"
                android:minHeight="0dp"
                android:paddingHorizontal="16dp"
                android:layout_marginEnd="8dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSetujui"
                android:layout_width="wrap_content"
                android:layout_height="34dp"
                android:text="Setujui"
                android:textSize="11sp"
                android:textColor="#FFFFFF"
                android:backgroundTint="#27AE60"
                app:cornerRadius="6dp"
                android:minWidth="0dp"
                android:minHeight="0dp"
                android:paddingHorizontal="16dp" />
        </LinearLayout>

    </LinearLayout>
</androidx.cardview.widget.CardView>
