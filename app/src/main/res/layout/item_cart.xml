<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:paddingVertical="12dp"
    android:gravity="center_vertical">

    <!-- Item details (Name + Qty x Price) -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvCartItemName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Kopi Susu Gula Aren"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="#333333"
            android:maxLines="2"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/tvCartItemSubtotal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="1 x Rp 15.000"
            android:textSize="13sp"
            android:textColor="#888888"
            android:layout_marginTop="2dp" />
    </LinearLayout>

    <!-- Total price and controls -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="end">

        <!-- Total Price for this item -->
        <TextView
            android:id="@+id/tvCartItemPrice"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Rp 15.000"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="#0A3D2E"
            android:layout_marginBottom="6dp" />

        <!-- Quantity Controls -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageButton
                android:id="@+id/btnCartDecrease"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@android:drawable/ic_media_previous"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:contentDescription="Decrease quantity"
                android:tint="#888888"/>

            <TextView
                android:id="@+id/tvCartItemQty"
                android:layout_width="32dp"
                android:layout_height="wrap_content"
                android:text="1"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="#333333"
                android:gravity="center" />

            <ImageButton
                android:id="@+id/btnCartIncrease"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@android:drawable/ic_input_add"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:contentDescription="Increase quantity"
                android:tint="#0A3D2E"/>
        </LinearLayout>
    </LinearLayout>

</LinearLayout>
