<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="2dp"
    android:layout_marginVertical="6dp"
    app:cardCornerRadius="10dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="14dp"
        android:gravity="center_vertical">

        <!-- Left Side: Transaction Icon & Info -->
        <ImageView
            android:id="@+id/ivTipeIcon"
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:background="@android:drawable/dialog_holo_light_frame"
            android:padding="8dp"
            android:scaleType="centerInside"
            android:src="@android:drawable/ic_menu_upload_you_tube"
            android:layout_marginEnd="12dp"
            app:tint="#E67E22" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_weight="1">

            <TextView
                android:id="@+id/tvRiwayatTipe"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Penyimpanan Gaji"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#2C3E50" />

            <TextView
                android:id="@+id/tvRiwayatTanggal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="2026-06-16"
                android:textSize="12sp"
                android:textColor="#7F8C8D"
                android:layout_marginTop="2dp" />

            <TextView
                android:id="@+id/tvRiwayatCatatan"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Catatan: -"
                android:textSize="11sp"
                android:textColor="#95A5A6"
                android:layout_marginTop="4dp"
                android:visibility="gone" />
        </LinearLayout>

        <!-- Right Side: Nominal & Status Badge -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="end">

            <TextView
                android:id="@+id/tvRiwayatNominal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Rp 120.000"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#2C3E50" />

            <!-- Status Badge Container with custom styling in code -->
            <TextView
                android:id="@+id/tvRiwayatStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Menunggu"
                android:textSize="10sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:background="#F39C12"
                android:paddingHorizontal="8dp"
                android:paddingVertical="3dp"
                android:layout_marginTop="4dp"
                android:gravity="center" />
        </LinearLayout>

    </LinearLayout>
</androidx.cardview.widget.CardView>
