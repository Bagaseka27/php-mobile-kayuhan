<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:paddingVertical="8dp"
    android:paddingHorizontal="4dp"
    android:gravity="center_vertical">

    <TextView android:id="@+id/tvIdJadwal"
        android:layout_width="60dp" android:layout_height="wrap_content"
        android:textColor="#212121" android:textSize="11sp" />

    <TextView android:id="@+id/tvNama"
        android:layout_width="110dp" android:layout_height="wrap_content"
        android:textColor="#212121" android:textSize="11sp" />

    <TextView android:id="@+id/tvLokasi"
        android:layout_width="100dp" android:layout_height="wrap_content"
        android:textColor="#212121" android:textSize="11sp" />

    <TextView android:id="@+id/tvTanggal"
        android:layout_width="90dp" android:layout_height="wrap_content"
        android:textColor="#212121" android:textSize="11sp" />

    <TextView android:id="@+id/tvJam"
        android:layout_width="110dp" android:layout_height="wrap_content"
        android:textColor="#212121" android:textSize="11sp" />

    <LinearLayout
        android:layout_width="80dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnEdit"
            android:layout_width="wrap_content"
            android:layout_height="26dp"
            android:text="Edit"
            android:textSize="10sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#FFA726"
            app:cornerRadius="4dp"
            android:minWidth="0dp" android:minHeight="0dp"
            android:paddingHorizontal="10dp"
            android:layout_marginBottom="3dp" /> <com.google.android.material.button.MaterialButton
        android:id="@+id/btnHapus"
        android:layout_width="wrap_content"
        android:layout_height="26dp"
        android:text="Hapus"
        android:textSize="10sp"
        android:textColor="#FFFFFF"
        android:backgroundTint="#EF5350"
        app:cornerRadius="4dp"
        android:minWidth="0dp" android:minHeight="0dp"
        android:paddingHorizontal="10dp" />
    </LinearLayout>
</LinearLayout>