<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F5E8"
    android:padding="16dp">

    <!-- Sub-menu Buttons Row (scrollable) -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        android:layout_marginBottom="12dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnPengambilanGaji"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="Pengambilan Gaji"
                android:textSize="10sp"
                android:textColor="#FFFFFF"
                android:backgroundTint="#1B5E3B"
                app:cornerRadius="8dp"
                android:minWidth="0dp"
                android:minHeight="0dp"
                android:paddingHorizontal="10dp"
                android:layout_marginEnd="6dp"
                app:icon="@android:drawable/ic_menu_edit"
                app:iconTint="#FFFFFF"
                app:iconSize="13dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnPenyimpananGaji"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="Penyimpanan Gaji"
                android:textSize="10sp"
                android:textColor="#FFFFFF"
                android:backgroundTint="#E67E22"
                app:cornerRadius="8dp"
                android:minWidth="0dp"
                android:minHeight="0dp"
                android:paddingHorizontal="10dp"
                android:layout_marginEnd="6dp"
                app:icon="@android:drawable/ic_menu_save"
                app:iconTint="#FFFFFF"
                app:iconSize="13dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnTabungan"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="Tabungan"
                android:textSize="10sp"
                android:textColor="#FFFFFF"
                android:backgroundTint="#2A9D8F"
                app:cornerRadius="8dp"
                android:minWidth="0dp"
                android:minHeight="0dp"
                android:paddingHorizontal="10dp"
                app:icon="@android:drawable/ic_menu_agenda"
                app:iconTint="#FFFFFF"
                app:iconSize="13dp" />
        </LinearLayout>
    </HorizontalScrollView>

    <!-- Hidden Tambah button (kept for binding compatibility) -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnTambahGaji"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="gone"
        android:text="Tambah" />

    <!-- Hidden periode filter (kept for binding compatibility) -->
    <com.google.android.material.textfield.TextInputEditText
        android:id="@+id/etPeriodeFilter"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone" />

    <!-- Table Gaji -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        app:cardCornerRadius="10dp"
        app:cardElevation="2dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:padding="8dp">

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:orientation="vertical">

                    <!-- Header -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:paddingVertical="8dp"
                        android:paddingHorizontal="4dp">

                        <TextView android:layout_width="40dp" android:layout_height="wrap_content"
                            android:text="NO" android:textColor="#555" android:textSize="10sp" android:textStyle="bold" />
                        <TextView android:layout_width="110dp" android:layout_height="wrap_content"
                            android:text="NAMA KARYAWAN" android:textColor="#555" android:textSize="10sp" android:textStyle="bold" />
                        <TextView android:layout_width="90dp" android:layout_height="wrap_content"
                            android:text="PERIODE" android:textColor="#555" android:textSize="10sp" android:textStyle="bold" />
                        <TextView android:layout_width="90dp" android:layout_height="wrap_content"
                            android:text="GAJI POKOK" android:textColor="#555" android:textSize="10sp" android:textStyle="bold" />
                        <TextView android:layout_width="70dp" android:layout_height="wrap_content"
                            android:text="BONUS" android:textColor="#555" android:textSize="10sp" android:textStyle="bold" />
                        <TextView android:layout_width="90dp" android:layout_height="wrap_content"
                            android:text="KOMPENSASI" android:textColor="#555" android:textSize="10sp" android:textStyle="bold" />
                        <TextView android:layout_width="110dp" android:layout_height="wrap_content"
                            android:text="TOTAL GAJI AKHIR" android:textColor="#555" android:textSize="10sp" android:textStyle="bold" />
                        <TextView android:layout_width="110dp" android:layout_height="wrap_content"
                            android:text="AKSI" android:textColor="#555" android:textSize="10sp" android:textStyle="bold"
                            android:gravity="center" />
                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#E0E0E0" />

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rvGaji"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:nestedScrollingEnabled="false" />

                </LinearLayout>
            </HorizontalScrollView>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

</LinearLayout>