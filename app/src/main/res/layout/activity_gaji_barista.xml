<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FAF8F5">

    <!-- Header Toolbar -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbarGaji"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="#2C3E50"
        app:title="Informasi Gaji Barista"
        app:titleTextColor="#FFFFFF"
        app:navigationIcon="?attr/homeAsUpIndicator"
        android:theme="@style/ThemeOverlay.AppCompat.Dark.ActionBar" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Card 1: Sisa Gaji Harian -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Sisa Gaji Hari Ini"
                        android:textSize="14sp"
                        android:textColor="#7F8C8D"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvSisaGajiHarian"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Rp 0"
                        android:textSize="22sp"
                        android:textColor="#2C3E50"
                        android:textStyle="bold"
                        android:layout_marginTop="4dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="* Belum disimpan ke tabungan atau ditarik"
                        android:textSize="11sp"
                        android:textColor="#95A5A6"
                        android:layout_marginTop="6dp"
                        android:textStyle="italic" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Card 2: Total Tabungan -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Total Tabungan"
                        android:textSize="14sp"
                        android:textColor="#7F8C8D"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvTotalTabungan"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Rp 0"
                        android:textSize="22sp"
                        android:textColor="#E67E22"
                        android:textStyle="bold"
                        android:layout_marginTop="4dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="* Saldo aman terakumulasi dari gaji harian"
                        android:textSize="11sp"
                        android:textColor="#95A5A6"
                        android:layout_marginTop="6dp"
                        android:textStyle="italic" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Card 3: Sisa Gaji (Bisa Diambil) - Terlihat Paling Menonjol -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                app:cardCornerRadius="14dp"
                app:cardElevation="6dp"
                app:cardBackgroundColor="#137356">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Total Bisa Diambil"
                        android:textSize="15sp"
                        android:textColor="#D5F5E3"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvSisaGajiTotal"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Rp 0"
                        android:textSize="28sp"
                        android:textColor="#FFFFFF"
                        android:textStyle="bold"
                        android:layout_marginTop="6dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Gabungan dari sisa gaji harian + tabungan saat ini"
                        android:textSize="12sp"
                        android:textColor="#E8F8F5"
                        android:layout_marginTop="8dp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Button Actions Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="2"
                android:layout_marginBottom="24dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnSimpanGaji"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="SIMPAN GAJI"
                    android:textSize="12sp"
                    android:textColor="#FFFFFF"
                    android:backgroundTint="#E67E22"
                    android:layout_marginEnd="6dp"
                    app:cornerRadius="8dp"
                    android:paddingVertical="12dp"
                    app:iconGravity="textStart" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnAmbilGaji"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="AMBIL GAJI"
                    android:textSize="12sp"
                    android:textColor="#FFFFFF"
                    android:backgroundTint="#2980B9"
                    android:layout_marginStart="6dp"
                    app:cornerRadius="8dp"
                    android:paddingVertical="12dp"
                    app:iconGravity="textStart" />

            </LinearLayout>

            <!-- Section Title: Riwayat Pengajuan -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Riwayat Pengajuan Gaji"
                android:textSize="16sp"
                android:textColor="#2C3E50"
                android:textStyle="bold"
                android:layout_marginBottom="10dp"/>

            <!-- RecyclerView for History -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvRiwayatGaji"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                tools:listitem="@layout/item_riwayat_gaji" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</LinearLayout>
