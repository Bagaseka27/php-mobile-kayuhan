<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="#FAF8F5">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="PRESENSI HADIR BARISTA"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="#333333"
        android:gravity="center"
        android:layout_marginBottom="20dp"/>

    <EditText
        android:id="@+id/etEmailBarista"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Masukkan Email Barista Terdaftar"
        android:inputType="textEmailAddress"
        android:layout_marginBottom="16dp"/>

    <ImageView
        android:id="@+id/ivFotoAbsen"
        android:layout_width="match_parent"
        android:layout_height="220dp"
        android:background="#EAEAEA"
        android:scaleType="centerCrop"
        android:src="@android:drawable/ic_menu_camera"
        android:layout_marginBottom="8dp"/>

    <Button
        android:id="@+id/btnAmbilFoto"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="BUKA KAMERA (AMBIL FOTO)"
        android:backgroundTint="#4A90E2"
        android:textColor="#FFFFFF"
        android:layout_marginBottom="16dp"/>

    <TextView
        android:id="@+id/tvLokasi"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Lokasi: Sedang melacak GPS..."
        android:textSize="14sp"
        android:textColor="#555555"
        android:layout_marginBottom="4dp"/>

    <TextView
        android:id="@+id/tvKoordinat"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Koordinat: Lat: 0.0, Lng: 0.0"
        android:textSize="12sp"
        android:textColor="#888888"
        android:layout_marginBottom="24dp"/>

    <Button
        android:id="@+id/btnKirimAbsen"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="KIRIM PRESENSI"
        android:backgroundTint="#2ECC71"
        android:textColor="#FFFFFF"
        android:textStyle="bold"/>
</LinearLayout>