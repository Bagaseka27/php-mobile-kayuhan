<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:background="#E9E4DB"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp">

    <!-- Judul + Tombol -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/tvTitleMenu"
            android:text="Manajemen Menu"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#0A3D2E"
            android:layout_weight="1"
            android:layout_width="0dp"
            android:layout_height="wrap_content"/>

        <Button
            android:id="@+id/btnTambah"
            android:text="+ Tambah Menu"
            android:textColor="#FFFFFF"
            android:backgroundTint="#0A3D2E"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>
    </LinearLayout>

    <!-- Card Table -->
    <androidx.cardview.widget.CardView
        android:layout_marginTop="20dp"
        app:cardCornerRadius="12dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none">

            <TableLayout
                android:id="@+id/tableMenu"
                android:padding="10dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content">

                <!-- Header -->
                <TableRow
                    android:background="#F3F3F3"
                    android:padding="4dp">

                    <TextView
                        android:text="ID"
                        android:textStyle="bold"
                        android:padding="8dp"
                        android:layout_width="55dp"/>

                    <TextView
                        android:text="Nama"
                        android:textStyle="bold"
                        android:padding="8dp"
                        android:layout_width="100dp"/>

                    <TextView
                        android:text="Kategori"
                        android:textStyle="bold"
                        android:padding="8dp"
                        android:layout_width="100dp"/>

                    <TextView
                        android:text="Harga"
                        android:textStyle="bold"
                        android:padding="8dp"
                        android:layout_width="80dp"/>

                    <TextView
                        android:id="@+id/tvHeaderAksi"
                        android:text="Aksi"
                        android:textStyle="bold"
                        android:gravity="center"
                        android:padding="8dp"
                        android:layout_width="160dp"/>

                </TableRow>

            </TableLayout>
        </HorizontalScrollView>

    </androidx.cardview.widget.CardView>

</LinearLayout>