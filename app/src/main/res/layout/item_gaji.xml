<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:paddingVertical="8dp"
    android:paddingHorizontal="4dp"
    android:gravity="center_vertical">

    <TextView android:id="@+id/tvNo"
        android:layout_width="40dp" android:layout_height="wrap_content"
        android:textColor="#333" android:textSize="11sp" />

    <TextView android:id="@+id/tvNama"
        android:layout_width="110dp" android:layout_height="wrap_content"
        android:textColor="#333" android:textSize="11sp" />

    <TextView android:id="@+id/tvPeriode"
        android:layout_width="90dp" android:layout_height="wrap_content"
        android:textColor="#333" android:textSize="11sp" />

    <TextView android:id="@+id/tvGajiPokok"
        android:layout_width="90dp" android:layout_height="wrap_content"
        android:textColor="#333" android:textSize="11sp" />

    <TextView android:id="@+id/tvBonus"
        android:layout_width="70dp" android:layout_height="wrap_content"
        android:textColor="#333" android:textSize="11sp" />

    <TextView android:id="@+id/tvKompensasi"
        android:layout_width="90dp" android:layout_height="wrap_content"
        android:textColor="#333" android:textSize="11sp" />

    <TextView android:id="@+id/tvTotalGaji"
        android:layout_width="110dp" android:layout_height="wrap_content"
        android:textColor="#1B5E3B" android:textSize="11sp" android:textStyle="bold" />

    <LinearLayout
        android:layout_width="110dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnEdit"
            android:layout_width="wrap_content"
            android:layout_height="26dp"
            android:text="Lihat"
            android:textSize="10sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#2A9D8F"
            app:cornerRadius="4dp"
            android:minWidth="0dp" android:minHeight="0dp"
            android:paddingHorizontal="10dp"
            android:layout_marginEnd="4dp"
            app:icon="@android:drawable/ic_menu_view"
            app:iconTint="#FFFFFF"
            app:iconSize="12dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnHapus"
            android:layout_width="wrap_content"
            android:layout_height="26dp"
            android:text="Hapus"
            android:textSize="10sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#E53935"
            app:cornerRadius="4dp"
            android:minWidth="0dp" android:minHeight="0dp"
            android:paddingHorizontal="10dp" />
    </LinearLayout>

</LinearLayout>