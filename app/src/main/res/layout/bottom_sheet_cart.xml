<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#FFFFFF"
    android:padding="16dp"
    app:layout_behavior="com.google.android.material.bottomsheet.BottomSheetBehavior">

    <!-- Handle indicator at the top -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:background="#DCDCDC"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="16dp" />

    <!-- Title Row -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Keranjang Belanja"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#333333"
            android:layout_alignParentStart="true" />

        <TextView
            android:id="@+id/tvClearCart"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Kosongkan"
            android:textSize="14sp"
            android:textColor="#FF0000"
            android:textStyle="bold"
            android:layout_alignParentEnd="true"
            android:clickable="true"
            android:focusable="true" />
    </RelativeLayout>

    <!-- Cart items recycler view -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvCartItems"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:maxHeight="250dp"
        android:layout_marginBottom="16dp" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#E0E0E0"
        android:layout_marginBottom="16dp" />

    <!-- Payment Method -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Metode Pembayaran"
        android:textSize="14sp"
        android:textStyle="bold"
        android:textColor="#555555"
        android:layout_marginBottom="12dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:weightSum="2"
        android:layout_marginBottom="20dp">

        <!-- Tunai option -->
        <LinearLayout
            android:id="@+id/optTunai"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:padding="12dp"
            android:layout_marginEnd="8dp"
            android:gravity="center"
            android:background="@drawable/bg_payment_selected"
            android:clickable="true"
            android:focusable="true">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tunai / Cash"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#0A3D2E" />
        </LinearLayout>

        <!-- QRIS option -->
        <LinearLayout
            android:id="@+id/optQris"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:padding="12dp"
            android:layout_marginStart="8dp"
            android:gravity="center"
            android:background="@drawable/bg_payment_unselected"
            android:clickable="true"
            android:focusable="true">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="QRIS"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#333333" />
        </LinearLayout>
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#E0E0E0"
        android:layout_marginBottom="16dp" />

    <!-- Total Price row -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Total Pembayaran"
            android:textSize="14sp"
            android:textColor="#888888"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true" />

        <TextView
            android:id="@+id/tvTotalPrice"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Rp 0"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#0A3D2E"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true" />
    </RelativeLayout>

    <!-- Pay button -->
    <Button
        android:id="@+id/btnBayar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="BAYAR SEKARANG"
        android:textColor="#FFFFFF"
        android:backgroundTint="#0A3D2E"
        android:padding="14dp"
        android:textStyle="bold"
        android:textSize="16sp" />

</LinearLayout>
